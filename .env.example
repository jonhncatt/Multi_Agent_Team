########################################
# Multi_Agent_Robot · Environment Sample
########################################

# Preferred LLM env keys (provider-agnostic naming)
OFFICETOOL_LLM_PROVIDER=openai
OFFICETOOL_LLM_AUTH_MODE=auto
# OFFICETOOL_LLM_API_KEY=<YOUR_API_KEY>
# OFFICETOOL_LLM_BASE_URL=https://api.openai.com/v1
OFFICETOOL_LLM_MODEL=gpt-5.1-chat
# OFFICETOOL_LLM_SUMMARY_MODEL=gpt-5.1-chat
# OFFICETOOL_LLM_TEMPERATURE=
# OFFICETOOL_LLM_USE_RESPONSES_API=false

# Legacy compatibility (still supported)
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# OFFICETOOL_OPENAI_AUTH_MODE=auto
# OFFICETOOL_OPENAI_BASE_URL=https://<YOUR_COMPANY_API_BASE>/v1
# OFFICETOOL_DEFAULT_MODEL=gpt-5.1-chat
# OFFICETOOL_SUMMARY_MODEL=gpt-5.1-chat
# OFFICETOOL_TEMPERATURE=
# OFFICETOOL_USE_RESPONSES_API=false

# Optional future multi-provider placeholders (for upcoming provider modules)
# OFFICETOOL_PROVIDER_OPENAI_API_KEY=
# OFFICETOOL_PROVIDER_ANTHROPIC_API_KEY=
# OFFICETOOL_PROVIDER_GEMINI_API_KEY=
# OFFICETOOL_PROVIDER_DEEPSEEK_API_KEY=
# OFFICETOOL_PROVIDER_MISTRAL_API_KEY=

# If using a company gateway with internal root CA
# OFFICETOOL_CA_CERT_PATH=/absolute/path/to/your-company-root-ca.cer

# Context & upload controls
# OFFICETOOL_SUMMARY_TRIGGER_TURNS=2000
# OFFICETOOL_MAX_CONTEXT_TURNS=2000
# OFFICETOOL_MAX_ATTACHMENT_CHARS=1000000
# OFFICETOOL_MAX_UPLOAD_MB=200

# Command allowlist
# OFFICETOOL_ALLOWED_COMMANDS=pwd,ls,cat,rg,head,tail,wc,find,echo,date,python3,git,npm,node,pytest,sed,awk,mkdir,touch,cp,mv

# File access scope
# OFFICETOOL_EXTRA_ALLOWED_ROOTS=/Users/<YOU>/Desktop/workbench;/Users/<YOU>/Downloads;/Users/<YOU>/Desktop
# OFFICETOOL_ALLOW_ANY_PATH=false
# OFFCIATOOL_ALLOW_ANY_PATH=false

# Web tool controls
# OFFICETOOL_WEB_ALLOWED_DOMAINS=
# OFFICETOOL_WEB_FETCH_TIMEOUT_SEC=12
# OFFICETOOL_WEB_FETCH_MAX_CHARS=120000
# OFFICETOOL_WEB_CA_CERT_PATH=/absolute/path/to/corp-root-ca.cer
# OFFICETOOL_WEB_SKIP_TLS_VERIFY=false

# Runtime controls
# OFFICETOOL_MAX_CONCURRENT_RUNS=2
# OFFICETOOL_RUN_QUEUE_WAIT_NOTICE_MS=1500
# OFFICETOOL_EXECUTION_MODE=host
# OFFICETOOL_DOCKER_BIN=docker
# OFFICETOOL_DOCKER_IMAGE=python:3.11-slim
# OFFICETOOL_DOCKER_NETWORK=none
# OFFICETOOL_DOCKER_MEMORY=2g
# OFFICETOOL_DOCKER_CPUS=1.0
# OFFICETOOL_DOCKER_PIDS_LIMIT=256
# OFFICETOOL_DOCKER_CONTAINER_PREFIX=officetool-sbx
# OFFICETOOL_ENABLE_SESSION_TOOLS=true
# OFFICETOOL_TOOL_RESULT_SOFT_TRIM_CHARS=40000
# OFFICETOOL_TOOL_RESULT_HARD_CLEAR_CHARS=180000
# OFFICETOOL_TOOL_RESULT_HEAD_CHARS=8000
# OFFICETOOL_TOOL_RESULT_TAIL_CHARS=4000
# OFFICETOOL_TOOL_CONTEXT_PRUNE_KEEP_LAST=3

# Note: legacy OFFCIATOOL_* names remain supported.
