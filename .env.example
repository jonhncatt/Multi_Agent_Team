# Vintage Programmer minimal env
# Copy this file to `.env`, then enable one profile below.

# Profile A: OpenAI API key
MULTI_AGENT_TEAM_LLM_PROVIDER=openai
OPENAI_API_KEY=

# Profile B: OpenAI via Codex auth
# Use this when `~/.codex/auth.json` already exists.
# MULTI_AGENT_TEAM_LLM_PROVIDER=openai
# MULTI_AGENT_TEAM_LLM_AUTH_MODE=codex_auth

# Profile C: local Ollama
# MULTI_AGENT_TEAM_LLM_PROVIDER=ollama
# MULTI_AGENT_TEAM_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# MULTI_AGENT_TEAM_DEFAULT_MODEL=qwen2.5-coder:7b

# Profile D: OpenAI-compatible / enterprise gateway
# Keep provider as `openai`. The app will use the OpenAI-compatible API path.
# MULTI_AGENT_TEAM_LLM_PROVIDER=openai
# OPENAI_API_KEY=your_gateway_key
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_BASE_URL=https://your-gateway.example.com/v1
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_CA_CERT_PATH=/absolute/path/to/your-root-ca.pem
# Optional aliases:
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
# SSL_CERT_FILE=/absolute/path/to/your-root-ca.pem

# Optional app settings
# MULTI_AGENT_TEAM_DEFAULT_MODEL=gpt-5.1
# MULTI_AGENT_TEAM_APP_PORT=8080
# MULTI_AGENT_TEAM_EXECUTION_MODE=host
# MULTI_AGENT_TEAM_MAX_UPLOAD_MB=50
# MULTI_AGENT_TEAM_ALLOWED_COMMANDS=pwd,ls,cat,rg,head,tail,wc,find,echo,date,python3,git,npm,node,pytest,sed,awk,mkdir,touch,cp,mv
# MULTI_AGENT_TEAM_WEB_ALLOWED_DOMAINS=

# Advanced provider-scoped env keys are still supported in `app/config.py`.
# They are intentionally omitted here to keep first-run setup small.
